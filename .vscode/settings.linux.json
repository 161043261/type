{
  "chat.editor.fontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "chat.editor.fontSize": 16,
  "cmake.pinnedCommands": [
    "workbench.action.tasks.configureTaskRunner",
    "workbench.action.tasks.runTask"
  ],
  "cmakeIntelliSence.cmakePath": "/usr/bin/cmake",
  "debug.console.fontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "debug.console.fontSize": 16,
  "debug.onTaskErrors": "abort",
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.codeLensFontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "editor.codeLensFontSize": 16,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.fontWeight": "normal",
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.indentSize": "tabSize",
  "editor.inlayHints.fontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "editor.inlayHints.fontSize": 16,
  "editor.inlineSuggest.fontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "editor.lineHeight": 1.5,
  "editor.minimap.enabled": false,
  "editor.minimap.sectionHeaderFontSize": 16,
  "editor.mouseWheelZoom": true,
  "editor.smoothScrolling": true,
  "editor.suggestFontSize": 16,
  "editor.tabSize": 2,
  "editor.trimAutoWhitespace": true,
  "editor.wordWrap": "on",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "files.autoSave": "afterDelay",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "lldb-dap.executable-path": "/usr/bin/lldb-dap-18",
  "makefile.configureOnOpen": true,
  "markdown.preview.fontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "markdown.preview.fontSize": 16,
  "notebook.formatOnCellExecution": true,
  "notebook.formatOnSave.enabled": true,
  "notebook.markup.fontSize": 16,
  "notebook.output.fontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "notebook.output.fontSize": 16,
  "notebook.output.wordWrap": true,
  "prettier.endOfLine": "lf",
  "prettier.tabWidth": 2,
  "python.analysis.autoIndent": true,
  "python.defaultInterpreterPath": "/home/user/venv/bin/python",
  "redhat.telemetry.enabled": true,
  "scm.inputFontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "scm.inputFontSize": 16,
  "screencastMode.fontSize": 24,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.external.linuxExec": "/usr/bin/zsh",
  "terminal.external.osxExec": "zsh",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.fontFamily": "Iosevka, Cascadia Code, Menlo, DejaVu Sans Mono, Yuanti SC, YouYuan, PingFang SC, Microsoft YaHei",
  "terminal.integrated.fontSize": 16,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vite.autoStart": false,
  "workbench.colorCustomizations": {
    "[Night Owl (No Italics)]": {
      "statusBar.debuggingBackground": "#E0E8F6"
    },
    "[Night Owl Light (No Italics)]": {
      "statusBar.debuggingBackground": "#E0E8F6"
    },
    "[Night Owl Light]": {
      "statusBar.debuggingBackground": "#E0E8F6"
    },
    "[Night Owl]": {
      "statusBar.debuggingBackground": "#E0E8F6"
    }
  },
  "workbench.colorTheme": "Night Owl Light",
  "workbench.editor.wrapTabs": true,
  "workbench.editorAssociations": {
    "{hexdiff}:/**/*.*": "hexEditor.hexedit",
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.svg": "default"
  },
  "workbench.iconTheme": "catppuccin-latte",
  "workbench.list.smoothScrolling": true
}
